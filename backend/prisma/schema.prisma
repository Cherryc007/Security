generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════

enum Role {
  SUPER_ADMIN
  ADMIN
  COMMAND_OPS
  SUPERVISOR
  GUARD
}

enum ShiftStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PatrolStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  MISSED
  DELAYED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  CLOSED
  ESCALATED
}

enum SOSStatus {
  ACTIVE
  RESPONDING
  RESOLVED
  FALSE_ALARM
}

enum AttendanceStatus {
  CLOCKED_IN
  CLOCKED_OUT
  ABSENT
  LATE
}

enum ZoneStatus {
  SECURE
  ATTENTION
  ALERT
  OFFLINE
}

// ═══════════════════════════════════════════════════
// CORE ENTITIES
// ═══════════════════════════════════════════════════

model Company {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  address   String?
  phone     String?
  email     String?
  logo      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites Site[]
  users User[]

  @@map("companies")
}

model User {
  id           String   @id @default(uuid())
  employeeId   String   @unique
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatar       String?
  role         Role     @default(GUARD)
  isActive     Boolean  @default(true)
  companyId    String
  siteId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company          Company            @relation(fields: [companyId], references: [id])
  site             Site?              @relation(fields: [siteId], references: [id])
  shiftAssignments ShiftAssignment[]
  patrolSessions   PatrolSession[]
  patrolScans      PatrolScan[]
  attendance       Attendance[]
  reportedIncidents Incident[]        @relation("ReportedBy")
  assignedIncidents Incident[]        @relation("AssignedTo")
  sosAlerts        SOSAlert[]
  refreshTokens    RefreshToken[]
  notifications    Notification[]
  locationRequestsTarget LocationRequest[] @relation("TargetUser")
  locationRequestsRequester LocationRequest[] @relation("RequesterUser")

  @@index([companyId])
  @@index([siteId])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ═══════════════════════════════════════════════════
// LOCATION HIERARCHY
// ═══════════════════════════════════════════════════

model Site {
  id        String   @id @default(uuid())
  name      String
  code      String
  address   String?
  companyId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id])
  users        User[]
  floors       Floor[]
  shifts       Shift[]
  patrolRoutes PatrolRoute[]
  incidents    Incident[]
  sosAlerts    SOSAlert[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("sites")
}

model Floor {
  id         String   @id @default(uuid())
  name       String
  number     Int
  siteId     String
  mapViewBox     String   @default("0 0 1000 600")
  layoutSvg      String?
  layoutImageUrl String?
  layoutWidth    Int?
  layoutHeight   Int?
  isActive       Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  site        Site         @relation(fields: [siteId], references: [id])
  zones       Zone[]
  checkpoints Checkpoint[]
  incidents   Incident[]

  @@unique([siteId, number])
  @@index([siteId])
  @@map("floors")
}

model Zone {
  id          String     @id @default(uuid())
  name        String
  code        String
  description String?
  status      ZoneStatus @default(SECURE)
  floorId     String
  mapX        Float?
  mapY        Float?
  mapWidth    Float?
  mapHeight   Float?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  floor       Floor        @relation(fields: [floorId], references: [id])
  checkpoints Checkpoint[]
  incidents   Incident[]

  @@unique([floorId, code])
  @@index([floorId])
  @@map("zones")
}

model Checkpoint {
  id        String   @id @default(uuid())
  name      String
  qrCode    String   @unique
  floorId   String
  zoneId    String
  mapX      Float?
  mapY      Float?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  floor              Floor                   @relation(fields: [floorId], references: [id])
  zone               Zone                    @relation(fields: [zoneId], references: [id])
  patrolScans        PatrolScan[]
  routeCheckpoints   PatrolRouteCheckpoint[]

  @@index([floorId])
  @@index([zoneId])
  @@map("checkpoints")
}

// ═══════════════════════════════════════════════════
// SHIFTS & ATTENDANCE
// ═══════════════════════════════════════════════════

model Shift {
  id        String      @id @default(uuid())
  name      String
  startTime String      // HH:mm format
  endTime   String      // HH:mm format
  siteId    String
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  site        Site              @relation(fields: [siteId], references: [id])
  assignments ShiftAssignment[]

  @@index([siteId])
  @@map("shifts")
}

model ShiftAssignment {
  id        String      @id @default(uuid())
  shiftId   String
  userId    String
  date      DateTime    @db.Date
  status    ShiftStatus @default(SCHEDULED)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  shift Shift @relation(fields: [shiftId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([shiftId, userId, date])
  @@index([userId])
  @@index([date])
  @@map("shift_assignments")
}

model Attendance {
  id           String           @id @default(uuid())
  userId       String
  date         DateTime         @db.Date
  clockIn      DateTime?
  clockOut     DateTime?
  status       AttendanceStatus @default(CLOCKED_IN)
  totalHours   Float?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
  @@index([userId])
  @@index([date])
  @@map("attendance")
}

// ═══════════════════════════════════════════════════
// PATROLS
// ═══════════════════════════════════════════════════

model PatrolRoute {
  id                String   @id @default(uuid())
  name              String
  description       String?
  siteId            String
  estimatedDuration Int      // minutes
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  site           Site                    @relation(fields: [siteId], references: [id])
  checkpoints    PatrolRouteCheckpoint[]
  patrolSessions PatrolSession[]

  @@index([siteId])
  @@map("patrol_routes")
}

model PatrolRouteCheckpoint {
  id           String @id @default(uuid())
  routeId      String
  checkpointId String
  sortOrder    Int
  
  route      PatrolRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  checkpoint Checkpoint  @relation(fields: [checkpointId], references: [id])

  @@unique([routeId, checkpointId])
  @@unique([routeId, sortOrder])
  @@map("patrol_route_checkpoints")
}

model PatrolSession {
  id            String       @id @default(uuid())
  routeId       String
  guardId       String
  scheduledAt   DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  status        PatrolStatus @default(PENDING)
  completionPct Float        @default(0)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  route  PatrolRoute  @relation(fields: [routeId], references: [id])
  guard  User         @relation(fields: [guardId], references: [id])
  scans  PatrolScan[]

  @@index([guardId])
  @@index([routeId])
  @@index([status])
  @@index([scheduledAt])
  @@map("patrol_sessions")
}

model PatrolScan {
  id           String   @id @default(uuid())
  sessionId    String
  checkpointId String
  guardId      String
  scannedAt    DateTime @default(now())
  latitude     Float?
  longitude    Float?
  notes        String?

  session    PatrolSession @relation(fields: [sessionId], references: [id])
  checkpoint Checkpoint    @relation(fields: [checkpointId], references: [id])
  guard      User          @relation(fields: [guardId], references: [id])

  @@unique([sessionId, checkpointId])
  @@index([sessionId])
  @@index([guardId])
  @@map("patrol_scans")
}

// ═══════════════════════════════════════════════════
// INCIDENTS & SOS
// ═══════════════════════════════════════════════════

model Incident {
  id          String           @id @default(uuid())
  title       String
  description String
  severity    IncidentSeverity @default(MEDIUM)
  status      IncidentStatus   @default(OPEN)
  siteId      String
  floorId     String?
  zoneId      String?
  latitude    Float?
  longitude   Float?
  reportedBy  String
  assignedTo  String?
  resolvedAt  DateTime?
  resolution  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  site     Site   @relation(fields: [siteId], references: [id])
  floor    Floor? @relation(fields: [floorId], references: [id])
  zone     Zone?  @relation(fields: [zoneId], references: [id])
  reporter User   @relation("ReportedBy", fields: [reportedBy], references: [id])
  assignee User?  @relation("AssignedTo", fields: [assignedTo], references: [id])

  @@index([siteId])
  @@index([status])
  @@index([severity])
  @@index([createdAt])
  @@map("incidents")
}

model SOSAlert {
  id         String    @id @default(uuid())
  userId     String
  siteId     String
  floorId    String?
  zoneId     String?
  status     SOSStatus @default(ACTIVE)
  message    String?
  latitude   Float?
  longitude  Float?
  resolvedAt DateTime?
  resolvedBy String?
  resolution String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
  site Site @relation(fields: [siteId], references: [id])

  @@index([userId])
  @@index([siteId])
  @@index([status])
  @@map("sos_alerts")
}

// ═══════════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════════

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   // patrol, incident, sos, system, attendance
  isRead    Boolean  @default(false)
  data      Json?    // Additional payload
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ═══════════════════════════════════════════════════
// ON-DEMAND LOCATION TRACKING
// ═══════════════════════════════════════════════════

model LocationRequest {
  id            String   @id @default(uuid())
  targetUserId  String   // Guard being tracked
  requesterId   String   // Supervisor/Admin requesting
  status        LocationRequestStatus @default(ACTIVE)
  expiresAt     DateTime // Auto-expire after session
  createdAt     DateTime @default(now())

  targetUser    User     @relation("TargetUser", fields: [targetUserId], references: [id])
  requester     User     @relation("RequesterUser", fields: [requesterId], references: [id])

  @@index([targetUserId])
  @@index([requesterId])
  @@index([status])
  @@map("location_requests")
}

enum LocationRequestStatus {
  ACTIVE
  COMPLETED
  TIMEOUT
}

